{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "VoidRun",
  "description": "Modern AI Sandbox platform for secure code execution.",
  "public": true,
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#0F3D3E",
    "light": "#E6F2F2",
    "dark": "#0F3D3E"
  },
  "appearance": {
    "default": "light"
  },
  "seo": {
    "indexing": "all"
  },
  "typography": {
    "headings": {
      "fontFamily": "Inter"
    },
    "body": {
      "fontFamily": "Inter"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "SDKs & API",
            "pages": [
              "sdks/overview",
              "sdks/typescript",
              "sdks/python"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/lifecycle",
              "core-concepts/code-execution",
              "core-concepts/shell-execution",
              "core-concepts/file-system",
              "core-concepts/file-watching",
              "core-concepts/pty",
              "core-concepts/background-commands"
            ]
          },
          {
            "group": "Environments",
            "pages": [
              "environments/custom-images",
              "environments/package-management"
            ]
          },
          {
            "group": "Networking",
            "pages": [
              "networking/internet-access",
              "networking/tailscale"
            ]
          },
          {
            "group": "Advanced Access",
            "pages": [
              "advanced/nested-containers",
              "advanced/ssh-vnc",
              "advanced/self-hosted"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Overview",
            "pages": ["examples/overview"]
          },
          {
            "group": "Sandbox patterns",
            "pages": [
              "examples/ai-code-interpreter",
              "examples/coding-agents-sandbox",
              "examples/ci-test-runner",
              "examples/github-actions",
              "examples/ephemeral-dev-environment",
              "examples/untrusted-user-code",
              "examples/file-ingest-etl",
              "examples/multi-step-job",
              "examples/background-process",
              "examples/interactive-pty",
              "examples/file-watching",
              "examples/list-and-cleanup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/voidrun.yml"
      }
    ]
  },
  "logo": {
    "light": "/logo/on-dark-theme.png",
    "dark": "/logo/on-light-theme.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dash.void-run.com"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/voidrun-ai"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/voidrun-ai"
    }
  }
}
